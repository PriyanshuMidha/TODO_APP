{
  "manifest_version": 3,
  "name": "FocusDock Quick Save",
  "version": "1.0.0",
  "description": "Save tasks and tabs directly into FocusDock.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "FocusDock"
  },
  "permissions": ["tabs"],
  "host_permissions": [
    "https://focusdock-api.onrender.com/*"
  ]
}
